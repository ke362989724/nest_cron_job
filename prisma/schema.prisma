generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model CustomIndex {
  id                  String                @id @db.Uuid
  symbol              String
  created_at          DateTime              @default(now()) @db.Timestamptz(3)
  updated_at          DateTime              @db.Timestamptz(3)
  custom_index_prices custom_index_prices[]
}

model balance_sheets {
  id                                          String   @id
  symbol                                      String
  date                                        DateTime @db.Timestamptz(3)
  reported_currency                           String
  cik                                         String?
  filing_date                                 DateTime @db.Timestamptz(3)
  accepted_date                               DateTime @db.Timestamptz(3)
  fiscal_year                                 String
  period                                      String
  cash_and_cash_equivalents                   Float?
  short_term_investments                      Float?
  cash_and_short_term_investments             Float?
  net_receivables                             Float?
  accounts_receivables                        Float?
  other_receivables                           Float?
  inventory                                   Float?
  prepaids                                    Float?
  other_current_assets                        Float?
  total_current_assets                        Float?
  property_plant_equipment_net                Float?
  goodwill                                    Float?
  intangible_assets                           Float?
  goodwill_and_intangible_assets              Float?
  long_term_investments                       Float?
  tax_assets                                  Float?
  other_non_current_assets                    Float?
  total_non_current_assets                    Float?
  other_assets                                Float?
  total_assets                                Float?
  total_payables                              Float?
  account_payables                            Float?
  other_payables                              Float?
  accrued_expenses                            Float?
  short_term_debt                             Float?
  capital_lease_obligations_current           Float?
  tax_payables                                Float?
  deferred_revenue                            Float?
  other_current_liabilities                   Float?
  total_current_liabilities                   Float?
  long_term_debt                              Float?
  deferred_revenue_non_current                Float?
  deferred_tax_liabilities_non_current        Float?
  other_non_current_liabilities               Float?
  total_non_current_liabilities               Float?
  other_liabilities                           Float?
  capital_lease_obligations                   Float?
  total_liabilities                           Float?
  treasury_stock                              Float?
  preferred_stock                             Float?
  common_stock                                Float?
  retained_earnings                           Float?
  additional_paid_in_capital                  Float?
  accumulated_other_comprehensive_income_loss Float?
  other_total_stockholders_equity             Float?
  total_stockholders_equity                   Float?
  total_equity                                Float?
  minority_interest                           Float?
  total_liabilities_and_total_equity          Float?
  total_investments                           Float?
  total_debt                                  Float?
  net_debt                                    Float?
  capital_lease_obligations_non_current       Float?
  created_at                                  DateTime @default(now()) @db.Timestamptz(3)
  updated_at                                  DateTime @db.Timestamptz(3)
  ticker_id                                   String   @db.Uuid
  tickers                                     tickers  @relation(fields: [ticker_id], references: [id])

  @@unique([ticker_id, date, period])
  @@index([ticker_id, period])
}

model chart_pattern_prices {
  id               String         @id @db.Uuid
  chart_pattern_id String         @db.Uuid
  df_start         DateTime       @db.Timestamptz(3)
  df_end           DateTime       @db.Timestamptz(3)
  start            DateTime       @db.Timestamptz(3)
  end              DateTime       @db.Timestamptz(3)
  points           Json
  ticker_id        String         @db.Uuid
  time_frame       TimeFrame
  created_at       DateTime       @default(now()) @db.Timestamptz(3)
  updated_at       DateTime       @db.Timestamptz(3)
  chart_patterns   chart_patterns @relation(fields: [chart_pattern_id], references: [id])
  tickers          tickers        @relation(fields: [ticker_id], references: [id])

  @@unique([df_start, df_end, chart_pattern_id, ticker_id])
  @@index([chart_pattern_id])
}

model chart_patterns {
  id                   String                 @id @db.Uuid
  name                 String
  symbol               String
  description          String
  isBull               Boolean
  created_at           DateTime               @default(now()) @db.Timestamptz(3)
  updated_at           DateTime               @db.Timestamptz(3)
  chart_pattern_prices chart_pattern_prices[]
}

model custom_index_prices {
  id              String      @id @db.Uuid
  date            DateTime    @db.Timestamptz(3)
  open            Float
  close           Float
  high            Float
  low             Float
  volume          Float
  vwap            Float
  change          Float
  change_percent  Float?
  time_frame      TimeFrame
  custom_index_id String      @db.Uuid
  created_at      DateTime    @default(now()) @db.Timestamptz(3)
  updated_at      DateTime    @db.Timestamptz(3)
  CustomIndex     CustomIndex @relation(fields: [custom_index_id], references: [id])

  @@unique([custom_index_id, date, time_frame], map: "custom_index_id_date_timeFrame_unique")
  @@index([date])
  @@index([time_frame])
}

model exchanges {
  id         String    @id @db.Uuid
  symbol     String    @unique
  created_at DateTime  @default(now()) @db.Timestamptz(3)
  updated_at DateTime  @db.Timestamptz(3)
  tickers    tickers[]
}

model income_statements {
  id                                          String   @id @db.Uuid
  symbol                                      String
  date                                        DateTime @db.Timestamptz(3)
  reported_currency                           String?
  cik                                         String?
  filing_date                                 DateTime @db.Timestamptz(3)
  accepted_date                               DateTime @db.Timestamptz(3)
  fiscal_year                                 String?
  period                                      String?
  revenue                                     Float?
  cost_of_revenue                             Float?
  gross_profit                                Float?
  research_and_development_expenses           Float?
  general_and_administrative_expenses         Float?
  selling_and_marketing_expenses              Float?
  selling_general_and_administrative_expenses Float?
  other_expenses                              Float?
  operating_expenses                          Float?
  cost_and_expenses                           Float?
  net_interest_income                         Float?
  interest_income                             Float?
  interest_expense                            Float?
  depreciation_and_amortization               Float?
  ebitda                                      Float?
  ebit                                        Float?
  non_operating_income_excluding_interest     Float?
  operating_income                            Float?
  total_other_income_expenses_net             Float?
  income_before_tax                           Float?
  income_tax_expense                          Float?
  net_income_from_continuing_operations       Float?
  net_income_from_discontinued_operations     Float?
  other_adjustments_to_net_income             Float?
  netIncome                                   Float?
  net_income_deductions                       Float?
  bottom_line_net_income                      Float?
  eps                                         Float?
  eps_diluted                                 Float?
  weighted_average_shs_out                    Float?
  weighted_average_shs_out_dil                Float?
  ticker_id                                   String   @db.Uuid
  created_at                                  DateTime @default(now()) @db.Timestamptz(3)
  updated_at                                  DateTime @db.Timestamptz(3)
  tickers                                     tickers  @relation(fields: [ticker_id], references: [id])

  @@unique([period, ticker_id, date])
}

model index_prices {
  id             String    @id @db.Uuid
  date           DateTime  @db.Timestamptz(3)
  open           Float
  close          Float
  high           Float
  low            Float
  volume         Float
  vwap           Float
  change         Float
  change_percent Float?
  time_frame     TimeFrame
  index_id       String    @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(3)
  updated_at     DateTime  @db.Timestamptz(3)
  indexes        indexes   @relation(fields: [index_id], references: [id])

  @@unique([index_id, date, time_frame], map: "index_id_date_timeFrame_unique")
  @@index([date])
  @@index([time_frame])
}

model indexes {
  id           String         @id @db.Uuid
  symbol       String
  created_at   DateTime       @default(now()) @db.Timestamptz(3)
  updated_at   DateTime       @db.Timestamptz(3)
  popularity   Int            @default(0)
  index_prices index_prices[]
  prices       prices[]
}

model industries {
  id                                    String                                  @id @db.Uuid
  name                                  String                                  @unique
  sector_id                             String                                  @db.Uuid
  created_at                            DateTime                                @default(now()) @db.Timestamptz(3)
  updated_at                            DateTime                                @db.Timestamptz(3)
  sectors                               sectors                                 @relation(fields: [sector_id], references: [id])
  industry_market_size_advance_declines industry_market_size_advance_declines[]
  tickers                               tickers[]
}

model industry_market_size_advance_declines {
  id              String     @id
  percent         Int
  advance_number  Int
  decline_number  Int
  advance_percent Float?
  time_frame      TimeFrame
  capital         String
  date            DateTime   @db.Timestamptz(3)
  industry_id     String     @db.Uuid
  created_at      DateTime   @default(now()) @db.Timestamptz(3)
  updated_at      DateTime   @db.Timestamptz(3)
  industries      industries @relation(fields: [industry_id], references: [id])

  @@unique([industry_id, date, capital])
  @@index([date])
}

model instrument_search {
  id              String                   @id @db.Uuid
  symbol          String
  name            String?
  popularity      Int                      @default(0)
  created_at      DateTime                 @default(now()) @db.Timestamptz(3)
  instrument_type InstrumentType
  updated_at      DateTime                 @db.Timestamptz(3)
  search_vector   Unsupported("tsvector")?

  @@unique([symbol, instrument_type])
  @@index([instrument_type])
  @@index([symbol])
}

model new_highs {
  id              String    @id @db.Uuid
  date            DateTime  @db.Timestamptz(3)
  time_frame      TimeFrame
  window          Int
  new_high_number Int
  new_low_number  Int
  diff            Int
  created_at      DateTime  @default(now()) @db.Timestamptz(3)
  updated_at      DateTime  @db.Timestamptz(3)

  @@unique([date, time_frame, window])
  @@index([date])
  @@index([time_frame])
}

model prices {
  id              String         @id @db.Uuid
  date            DateTime       @db.Timestamptz(3)
  open            Float
  close           Float
  high            Float
  low             Float
  volume          Float
  vwap            Float
  change          Float
  change_percent  Float?
  time_frame      TimeFrame
  ticker_id       String?        @db.Uuid
  sector_etf_id   String?        @db.Uuid
  index_id        String?        @db.Uuid
  instrument_type InstrumentType
  created_at      DateTime       @default(now()) @db.Timestamptz(3)
  updated_at      DateTime       @db.Timestamptz(3)
  indexes         indexes?       @relation(fields: [index_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sector_etfs     sector_etfs?   @relation(fields: [sector_etf_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickers         tickers?       @relation(fields: [ticker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([index_id, date, time_frame], map: "indexId_date_timeFrame_unique")
  @@unique([sector_etf_id, date, time_frame], map: "sectorETFId_date_timeFrame_unique")
  @@unique([ticker_id, date, time_frame], map: "tickerId_date_timeFrame_unique")
  @@index([date])
  @@index([index_id])
  @@index([instrument_type])
  @@index([sector_etf_id])
  @@index([ticker_id])
  @@index([time_frame])
}

model rs_rankings {
  id             String   @id @db.Uuid
  date           DateTime @db.Timestamptz(3)
  rank           Float
  ticker_id      String   @db.Uuid
  weighted_score Float
  created_at     DateTime @default(now()) @db.Timestamptz(3)
  updated_at     DateTime @db.Timestamptz(3)
  popularity     Int      @default(0)
  tickers        tickers  @relation(fields: [ticker_id], references: [id])

  @@unique([ticker_id, date])
  @@index([date])
}

model sector_ETF_prices {
  id             String      @id @db.Uuid
  date           DateTime    @db.Timestamptz(3)
  open           Float
  close          Float
  high           Float
  low            Float
  volume         Float
  vwap           Float
  change         Float
  change_percent Float?
  time_frame     TimeFrame
  created_at     DateTime    @default(now()) @db.Timestamptz(3)
  updated_at     DateTime    @db.Timestamptz(3)
  sector_ETF_id  String      @db.Uuid
  sector_etfs    sector_etfs @relation(fields: [sector_ETF_id], references: [id])

  @@unique([sector_ETF_id, date, time_frame], map: "ETF_id_date_timeFrame_unique")
  @@index([date])
  @@index([time_frame])
}

model sector_etfs {
  id                String              @id @db.Uuid
  symbol            String              @unique
  sector_id         String              @db.Uuid
  created_at        DateTime            @default(now()) @db.Timestamptz(3)
  updated_at        DateTime            @db.Timestamptz(3)
  popularity        Int                 @default(0)
  name              String              @unique
  prices            prices[]
  sector_ETF_prices sector_ETF_prices[]
  sectors           sectors             @relation(fields: [sector_id], references: [id])
}

model sector_market_size_advance_decline {
  id              String    @id
  percent         Int
  advance_number  Int
  decline_number  Int
  capital         String
  date            DateTime  @db.Timestamptz(3)
  sector_id       String    @db.Uuid
  time_frame      TimeFrame
  advance_percent Float?
  created_at      DateTime  @default(now()) @db.Timestamptz(3)
  updated_at      DateTime  @db.Timestamptz(3)
  sectors         sectors   @relation(fields: [sector_id], references: [id])

  @@unique([sector_id, date, capital, time_frame])
}

model sectors {
  id                                 String                               @id @db.Uuid
  name                               String                               @unique
  created_at                         DateTime                             @default(now()) @db.Timestamptz(3)
  updated_at                         DateTime                             @db.Timestamptz(3)
  industries                         industries[]
  sector_etfs                        sector_etfs[]
  sector_market_size_advance_decline sector_market_size_advance_decline[]
  tickers                            tickers[]
}

model ticker_prices {
  id             String    @id @db.Uuid
  date           DateTime  @db.Timestamptz(3)
  open           Float
  close          Float
  high           Float
  low            Float
  volume         Float
  vwap           Float?
  change         Float?
  change_percent Float?
  time_frame     TimeFrame
  ticker_id      String?   @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(3)
  updated_at     DateTime  @db.Timestamptz(3)
  tickers        tickers?  @relation(fields: [ticker_id], references: [id])

  @@unique([ticker_id, date, time_frame], map: "ticker_price_tickerId_date_timeFrame_unique")
  @@index([date])
  @@index([ticker_id])
  @@index([time_frame])
}

model tickers {
  id                   String                 @id @db.Uuid
  name                 String
  symbol               String                 @unique
  is_actively_trading  Boolean
  country              String
  sector_id            String                 @db.Uuid
  exchange_id          String                 @db.Uuid
  industry_id          String                 @db.Uuid
  market_cap           Float?
  created_at           DateTime               @default(now()) @db.Timestamptz(3)
  updated_at           DateTime               @db.Timestamptz(3)
  popularity           Int                    @default(0)
  balance_sheets       balance_sheets[]
  chart_pattern_prices chart_pattern_prices[]
  income_statements    income_statements[]
  prices               prices[]
  rs_rankings          rs_rankings[]
  ticker_prices        ticker_prices[]
  exchanges            exchanges              @relation(fields: [exchange_id], references: [id])
  industries           industries             @relation(fields: [industry_id], references: [id])
  sectors              sectors                @relation(fields: [sector_id], references: [id])
  volume_spikes        volume_spikes[]
}

model volume_spikes {
  id                      String   @id @db.Uuid
  ticker_id               String   @db.Uuid
  window                  Int
  threshold_volume        Float
  threshold_price_percent Float
  final_volume            Float
  final_price_percent     Float
  date                    DateTime @db.Timestamptz(3)
  created_at              DateTime @default(now()) @db.Timestamptz(3)
  updated_at              DateTime @db.Timestamptz(3)
  tickers                 tickers  @relation(fields: [ticker_id], references: [id])

  @@unique([ticker_id, date, window])
}

enum InstrumentType {
  TICKER
  ETF
  INDEX
}

enum TimeFrame {
  MIN_15
  HOUR_1
  DAY_1
  REAL_TIME
}
